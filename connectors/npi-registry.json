{
  "name": "NPI Registry",
  "slug": "npi-registry",
  "description": "National Provider Identifier registry for healthcare providers",
  "category": "knowledge",
  "color": "#003B71",
  "website": "https://npiregistry.cms.hhs.gov",
  "authType": "none",
  "baseUrl": "https://npiregistry.cms.hhs.gov/api",
  "actions": [
