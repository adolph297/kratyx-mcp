          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          }
        }
      }
    }
  ],
  "icon": "npi-registry",
  "webhookSupport": false,
  "rateLimits": {
    "requestsPerMinute": 60
  },
  "documentation": "https://npiregistry.cms.hhs.gov/docs",
  "version": "1.0.0",
