{
  "name": "NetSuite",
  "slug": "netsuite",
  "description": "Oracle's cloud ERP platform for business management",
  "category": "finance",
  "color": "#B71C1C",
  "website": "https://www.netsuite.com",
  "authType": "oauth",
  "baseUrl": "https://rest.netsuite.com/rest",
  "authConfig": {
    "clientId": "",
    "clientSecret": "",
    "authUrl": "https://system.netsuite.com/app/login/oauth2/authorize.nl",
    "tokenUrl": "https://system.netsuite.com/app/login/oauth2/token.nl",
    "scopes": [
      "restlets",
      "rest_webservices"
    ],
    "responseType": "code",
    "grantType": "authorization_code"
  },
  "actions": [
    {
      "name": "query",
      "displayName": "Run SuiteQL",
      "description": "Execute a SuiteQL query",
      "method": "POST",
      "endpoint": "/query/v1/suiteql",
      "inputSchema": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string"
          }
        }
      }
    }
  ],
  "icon": "netsuite",
  "webhookSupport": false,
  "rateLimits": {
    "requestsPerMinute": 60
  },
  "documentation": "https://www.netsuite.com/docs",
  "version": "1.0.0",
  "status": "active"
}