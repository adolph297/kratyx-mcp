  "authConfig": { "clientId": "", "clientSecret": "", "authUrl": "https://discord.com/api/oauth2/authorize", "tokenUrl": "https://discord.com/api/oauth2/token", "scopes": ["identify", "guilds", "messages.read"], "responseType": "code", "grantType": "authorization_code" },
  "actions": [
