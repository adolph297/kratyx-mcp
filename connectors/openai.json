    { "name": "list_models", "displayName": "List Models", "description": "List available models", "method": "GET", "endpoint": "/models", "inputSchema": {} },
    { "name": "create_image", "displayName": "Create Image", "description": "Generate an image with DALL-E", "method": "POST", "endpoint": "/images/generations", "inputSchema": { "type": "object", "properties": { "prompt": { "type": "string" }, "n": { "type": "number", "default": 1 } } } }
