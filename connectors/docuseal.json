{
  "name": "DocuSeal",
  "slug": "docuseal",
  "description": "Open-source document signing and e-signature platform",
  "category": "productivity",
  "color": "#1E40AF",
  "website": "https://docuseal.co",
  "authType": "api_key",
  "baseUrl": "https://api.docuseal.co",
  "apiKeyConfig": {
    "headerName": "X-Auth-Token",
    "location": "header"
  },
  "actions": [
    {
      "name": "list_templates",
      "displayName": "List Templates",
      "description": "List document templates",
      "method": "GET",
      "endpoint": "/templates",
      "inputSchema": {}
    },
    {
      "name": "create_submission",
      "displayName": "Create Submission",
      "description": "Create a signing submission",
      "method": "POST",
      "endpoint": "/submissions",
      "inputSchema": {
        "type": "object",
        "properties": {
          "template_id": {
            "type": "number"
          },
          "submitters": {
            "type": "array"
          }
        }
      }
    }
  ],
  "icon": "docuseal",
  "webhookSupport": false,
  "rateLimits": {
    "requestsPerMinute": 60
  },
  "documentation": "https://docuseal.co/docs",
  "version": "1.0.0",
  "status": "active"
}