          }
        }
      }
    },
    {
      "name": "get_me",
      "displayName": "Get My Profile",
      "description": "Get authenticated user",
      "method": "GET",
      "endpoint": "/users/me",
      "inputSchema": {}
    }
  ],
  "icon": "twitter",
  "webhookSupport": false,
  "rateLimits": {
    "requestsPerMinute": 60
  },
