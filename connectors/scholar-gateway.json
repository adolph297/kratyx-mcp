      "inputSchema": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string"
          },
          "engine": {
            "type": "string"
          }
        }
      }
    }
  ],
  "icon": "scholar-gateway",
  "webhookSupport": false,
  "rateLimits": {
    "requestsPerMinute": 60
  },
  "documentation": "https://scholar.google.com/docs",
  "version": "1.0.0",
  "status": "active"
}