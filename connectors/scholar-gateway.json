{
  "name": "Scholar Gateway",
  "slug": "scholar-gateway",
  "description": "Academic research paper search and discovery platform",
  "category": "knowledge",
  "color": "#4285F4",
  "website": "https://scholar.google.com",
  "authType": "none",
  "baseUrl": "https://serpapi.com",
  "actions": [
    {
      "name": "search_papers",
