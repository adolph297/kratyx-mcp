{
  "name": "Snowflake",
  "slug": "snowflake",
  "description": "Cloud data platform for data warehousing and analytics",
  "category": "data",
  "color": "#29B5E8",
  "website": "https://snowflake.com",
  "authType": "api_key",
  "baseUrl": "https://account.snowflakecomputing.com/api/v2",
  "apiKeyConfig": {
    "headerName": "Authorization",
    "prefix": "Bearer ",
    "location": "header"
  },
  "actions": [
    {
      "name": "execute_statement",
      "displayName": "Execute Statement",
      "description": "Execute a SQL statement",
      "method": "POST",
      "endpoint": "/statements",
      "inputSchema": {
        "type": "object",
        "properties": {
          "statement": {
            "type": "string"
          },
          "database": {
            "type": "string"
          }
        }
      }
    }
  ],
  "icon": "snowflake",
  "webhookSupport": false,
  "rateLimits": {
    "requestsPerMinute": 60
  },
  "documentation": "https://snowflake.com/docs",
  "version": "1.0.0",
  "status": "active"
}