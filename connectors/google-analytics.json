{
  "name": "Google Analytics",
  "slug": "google-analytics",
  "description": "Web analytics service for tracking website traffic and user behavior",
  "category": "analytics",
  "color": "#E37400",
  "website": "https://analytics.google.com",
  "authType": "oauth",
  "baseUrl": "https://analyticsdata.googleapis.com/v1beta",
  "authConfig": {
    "clientId": "",
    "clientSecret": "",
    "authUrl": "https://accounts.google.com/o/oauth2/v2/auth",
    "tokenUrl": "https://oauth2.googleapis.com/token",
    "scopes": [
      "https://www.googleapis.com/auth/analytics.readonly"
    ],
    "responseType": "code",
    "grantType": "authorization_code"
  },
  "actions": [
    {
      "name": "run_report",
      "displayName": "Run Report",
      "description": "Run an analytics report",
      "method": "POST",
      "endpoint": "/properties/{propertyId}:runReport",
      "inputSchema": {
        "type": "object",
        "properties": {
          "propertyId": {
            "type": "string"
          }
        }
      }
    }
  ],
  "icon": "google-analytics",
  "webhookSupport": false,
  "rateLimits": {
    "requestsPerMinute": 60
  },
  "documentation": "https://analytics.google.com/docs",
  "version": "1.0.0",
  "status": "active"
}